# ── Smart IoT Lab Vision Backend — Environment Variables ──

# Your Roboflow API key
# Get it from: https://app.roboflow.com → Settings → Roboflow API
ROBOFLOW_API_KEY=
# Your Firebase Realtime Database URL
# Same value as DATABASE_URL in your ESP32 code
FIREBASE_DATABASE_URL=

# Port to run the backend on (default 3001)
PORT=3001